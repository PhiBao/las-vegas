# Public app URL used in agent entry cards.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public Sphere recipient controlled by the jackpot vault wallet.
# Use a testnet nametag, for example @sphere-jackpot-vault, or a DIRECT:// address.
NEXT_PUBLIC_JACKPOT_VAULT_RECIPIENT=

# Shared persistence for a live public app. Required for deployment.
# Local development falls back to .data/jackpot-store.json when this is empty.
DATABASE_URL=

# Fresh testnet-only vault wallet mnemonic. Never use a personal wallet mnemonic.
JACKPOT_VAULT_MNEMONIC=
JACKPOT_VAULT_NAMETAG=

# Cron protection. Vercel Cron sends this as Authorization: Bearer $CRON_SECRET when set.
CRON_SECRET=

# Sphere oracle API key. Defaults to the public testnet2 key if not set.
SPHERE_ORACLE_API_KEY=

# Product tuning.
ROUND_DURATION_MINUTES=240
JACKPOT_ENTRY_AMOUNT_USDU=1

# Optional local-only paths.
JACKPOT_STORAGE_FILE=.data/jackpot-store.json
JACKPOT_WALLET_DATA_DIR=.data/jackpot-vault/wallet
JACKPOT_WALLET_TOKENS_DIR=.data/jackpot-vault/tokens
